# URL pública de la API (solo para desarrollo con túnel).
# Cuando uses ngrok: copia este archivo a .env y pon la URL que te dé ngrok, ej.:
#   VITE_API_PUBLIC_URL=https://a1b2c3d4.ngrok-free.app
# Así en Panel → Configuración la URL del webhook de Chatwoot saldrá correcta para copiar.
VITE_API_PUBLIC_URL=

# Base URL per a les crides a l'API des del navegador (opcional).
# En dev amb proxy (npm run dev) no cal. Si la pestanya "Agents IA" surt buida, prova amb:
#   VITE_API_URL=http://localhost:3001
VITE_API_URL=
