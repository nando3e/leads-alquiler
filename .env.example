# Base de datos (PostgreSQL)
DATABASE_URL=postgresql://usuario:password@host:puerto/leads_qualifier

# Super admin (no está en DB; se valida contra estas variables)
SUPER_ADMIN_USERNAME=admin
# Opción A: contraseña en claro (solo desarrollo). Si usas esta, deja PASSWORD_HASH vacío.
SUPER_ADMIN_PASSWORD=
# Opción B: hash bcrypt (recomendado en producción). Generar: cd api && node -e "require('bcryptjs').hash('tu_password', 10).then(console.log)"
SUPER_ADMIN_PASSWORD_HASH=

# JWT para sesión del panel
JWT_SECRET=cambiar-en-produccion

# Webhook n8n: se llama cuando un lead cumple una regla de alerta (URL en .env)
N8N_ALERT_WEBHOOK_URL=https://tu-n8n.com/webhook/alert-lead

# Webhook "formulario enviado": solo se llama la primera vez (lead nuevo), no al actualizar
WEBHOOK_FORMULARIO_ENVIADO=https://tu-n8n.com/webhook/formulario-enviado

# App (nombre para títulos; ej. Gestoria Agil)
APP_NAME=Gestoria Agil

# Número WhatsApp "Volver a WhatsApp" (formulario). Si no está en panel_config, se usa este.
WHATSAPP_RETURN_NUMBER=

# Server
PORT=3001
NODE_ENV=development

# Frontend (URL base del formulario/panel para CORS si aplica)
FRONTEND_URL=http://localhost:5173
