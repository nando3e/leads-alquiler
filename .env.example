# Identificador del cliente (debe coincidir con CLIENT_KEY del compose del cliente)
# Determina el nombre de la red interna y del contenedor de postgres
CLIENT_KEY=nombre_cliente

# Dominio público de la app (Traefik lo usa para enrutar)
DOMAIN=leads.tudominio.com

# Base de datos (PostgreSQL)
# En producción con Docker: host = ${CLIENT_KEY}-postgres (red interna, sin puerto externo)
# En local: usar la URL con puerto externo
DATABASE_URL=postgresql://usuario:password@nombre_cliente-postgres:5432/leads_qualifier

# Super admin (no está en DB; se valida contra estas variables)
SUPER_ADMIN_USERNAME=admin
# Opción A: contraseña en claro (solo desarrollo). Si usas esta, deja PASSWORD_HASH vacío.
SUPER_ADMIN_PASSWORD=
# Opción B: hash bcrypt (recomendado en producción). Generar: cd api && node -e "require('bcryptjs').hash('tu_password', 10).then(console.log)"
SUPER_ADMIN_PASSWORD_HASH=

# JWT para sesión del panel
JWT_SECRET=cambiar-en-produccion

# Webhook n8n: se llama cuando un lead cumple una regla de alerta (URL en .env)
N8N_ALERT_WEBHOOK_URL=https://tu-n8n.com/webhook/alert-lead

# Webhook "formulario enviado": solo se llama la primera vez (lead nuevo), no al actualizar
WEBHOOK_FORMULARIO_ENVIADO=https://tu-n8n.com/webhook/formulario-enviado

# App (nombre para títulos; ej. Gestoria Agil)
APP_NAME=Gestoria Agil

# Número WhatsApp "Volver a WhatsApp" (formulario). Si no está en panel_config, se usa este.
WHATSAPP_RETURN_NUMBER=

# Teléfono de administración (se muestra al usuario en caso de compra genérica)
TELEFONO_ADMINISTRACION=

# Chatwoot (para que el bot envíe mensajes de vuelta)
CHATWOOT_URL=https://tu-chatwoot.com
CHATWOOT_TOKEN=

# BuilderBot (notificaciones a agente humano en casos de compra)
BUILDERBOT_PROJECT=
BUILDERBOT_TOKEN=

# OpenAI (LLM para la conversación del bot)
OPENAI_API_KEY=

# SMTP para notificaciones por email al administrador (cuando se dispara una alerta)
# Funciona con Gmail, Mailgun, Brevo/Sendinblue, Resend, o cualquier SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Server
PORT=3001
NODE_ENV=development

# Frontend (URL base del formulario/panel para CORS si aplica)
FRONTEND_URL=http://localhost:5173
